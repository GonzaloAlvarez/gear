#!/usr/bin/env python3
import subprocess
import sys
import time

VERSION = "1.0.0"
PROBE_TIMEOUT = 15
RECOVER_WAIT = 90
POLL = 3


def engine_up():
    try:
        return subprocess.run(
            ["docker", "ps"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=PROBE_TIMEOUT,
        ).returncode == 0
    except Exception:
        return False


def main():
    args = sys.argv[1:]
    if any(a in ("--version", "-v", "version") for a in args):
        print(VERSION)
        return 0
    force = any(a in ("-f", "--force") for a in args)

    if not force and engine_up():
        print("docker engine is healthy")
        return 0

    print("docker engine unresponsive; restarting Docker Desktop...")
    try:
        subprocess.run(["docker", "desktop", "restart"], timeout=120)
    except Exception as e:
        print(f"could not trigger restart: {e}", file=sys.stderr)
        return 1

    deadline = time.monotonic() + RECOVER_WAIT
    while time.monotonic() < deadline:
        if engine_up():
            print("docker engine recovered")
            return 0
        time.sleep(POLL)

    print("docker engine did not recover in time", file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main())
